{
  "fileheader.configObj": {
    "autoAdd": true,
    "autoAddLine": 100,
    "supportAutoLanguage": ["js"],
    "prohibitAutoAdd": ["md", "txt", "yaml", "lsr", "lcf", "list"],
    "atSymbol": ["@", "@"],
    "atSymbolObj": {
      "js": ["", "@"]
    },
    // 头部注释字段长度 默认为13
    "wideNum": 16,
    "showErrorMessage": false,
    "language": {},
    "functionParams": {},
    "dateFormat": "YYYY-MM-DD HH:mm:ss ZZ",
    "specialOptions": {
      "FilePath": "NAME",
      "LastEditTime": "UPDATED",
      "LastEditors": "UPDATER",
      "Description": "DESC"
    },
    "filePathColon": "/"
  },
  "fileheader.customMade": {
    "FilePath": "only file name without ext",
    "AUTHOR": "git config user.name",
    "REPO": "https://github.com/JY-Mar/scat-proxy",
    "LastEditors": "git config user.name",
    "LastEditTime": "Do not edit",
    "Description": "文件描述"
  },
  "emeraldwalk.runonsave": {
    "commands": [
      {
        "match": ".*(\\/|\\\\)Clash(\\/|\\\\)Rules(\\/|\\\\).+\\.yaml$",
        "cmd": "node \"${workspaceFolder}/toolsForNode/rewriteForYaml.js\" \"${file}\""
      },
      {
        "match": ".*(\\/|\\\\)Loon(\\/|\\\\)Rules(\\/|\\\\).+\\.lsr$",
        "cmd": "node \"${workspaceFolder}/toolsForNode/rewriteForLsr.js\" \"${file}\""
      },
      {
        "match": ".*(\\/|\\\\)General(\\/|\\\\)Rules(\\/|\\\\).+\\.list$",
        "cmd": "node \"${workspaceFolder}/toolsForNode/rewriteForList.js\" \"${file}\""
      }
    ]
  }
}
