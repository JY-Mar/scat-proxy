[Proxy Group]
🚀节点选择 = select,♻️自动选择,🚀手动切换,🎯全球直连,🇭🇰香港,🇲🇴澳门,🇨🇳台湾,🇯🇵日本,🇰🇷韩国,🇸🇬星洲,🇲🇾马来,🇮🇳印度,🇺🇸美国,🇨🇦加拿大,🇦🇺澳洲,🇬🇧英国,🇳🇱荷兰,🇱🇺卢森堡,🇱🇹立陶宛,img-url = https://jy-mar.github.io/scat-proxy/Icons/Color/Filter.png
♻️自动选择 = url-test,Filter_Global,interval = 300,tolerance = 50,img-url = https://jy-mar.github.io/scat-proxy/Icons/Color/Auto.png
🚀手动切换 = select,🇭🇰香港,🇲🇴澳门,🇨🇳台湾,🇯🇵日本,🇰🇷韩国,🇸🇬星洲,🇲🇾马来,🇮🇳印度,🇺🇸美国,🇨🇦加拿大,🇦🇺澳洲,🇬🇧英国,🇳🇱荷兰,🇱🇺卢森堡,🇱🇹立陶宛,🎯全球直连,img-url = https://jy-mar.github.io/scat-proxy/Icons/Color/Manual.png
# ⚠️流量用量 = select,Filter_Used,img-url = https://jy-mar.github.io/scat-proxy/Icons/Color/Available.png
🎯全球直连 = select,DIRECT,img-url = https://jy-mar.github.io/scat-proxy/Icons/Color/Direct.png
